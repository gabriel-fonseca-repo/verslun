# =============================================================================
# Verslun — Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=verslun
POSTGRES_PASSWORD=verslun_dev_password
POSTGRES_DB=verslun_development
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -- Redis --------------------------------------------------------------------
REDIS_URL=redis://:verslun_redis_password@localhost:6379/0
REDIS_PASSWORD=verslun_redis_password
REDIS_PORT=6379
